OPENCLAW_HOME=/home/your_vm_user/.openclaw
DISCORD_CHANNEL_ID=your_discord_channel_id
CRON_JOB_ID=your_cron_job_id
# Optional: support multiple OpenClaw cron jobs (comma-separated).
# If set, vm_bridge uses the latest story across these jobs.
# CRON_JOB_IDS=your_cron_job_id,SECOND_JOB_ID

# VM reaches Mac via reverse tunnel to localhost:19090
MAC_API_URL=http://127.0.0.1:19090
MAC_API_TOKEN=change_me

# Bridge -> Mac API reliability
# /generate can take many minutes with local ComfyUI, so keep this high.
MAC_API_GENERATE_TIMEOUT_SEC=5400
MAC_API_PUBLISH_TIMEOUT_SEC=300
MAC_API_STATUS_TIMEOUT_SEC=20
MAC_API_RETRIES=2
MAC_API_RETRY_BACKOFF_SEC=4
PUBLISH_COMMAND_ENABLED=false
IDEA_COMMAND_AS_PROMPT_ENABLED=true
TREND_SELECTION_ENABLED=true
TREND_SELECTION_MAX_OPTIONS=6
# Web research enrichment for trend signals (used for TREND list + prompt injection).
TREND_WEB_RESEARCH_ENABLED=true
TREND_WEB_RESEARCH_MAX_SIGNALS=6
TREND_WEB_RESEARCH_MAX_TITLES_PER_SOURCE=3
TREND_WEB_RESEARCH_TIMEOUT_SEC=12
TREND_WEB_RESEARCH_GEO=US
TREND_WEB_RESEARCH_USE_GOOGLE_NEWS=true
TREND_WEB_RESEARCH_USE_DUCKDUCKGO=true
# Default generation diversity (also when no TREND command is used).
# Comma-separated; bridge rotates and avoids repeating recent modes.
CONTENT_MODE_ROTATION=Story Drama,Fact Explainer,Current-News Brief,Mega-Build/Engineering Showcase,Myth-busting
CONTENT_MODE_AVOID_REPEAT_WINDOW=2

# Dynamic topic discovery for NO -> rerun
THEME_DISCOVERY_ENABLED=true
THEME_DISCOVERY_GEO=US
THEME_DISCOVERY_MAX_TOPICS=8
# TikTok Creative Center trend signals (primary source)
THEME_DISCOVERY_TIKTOK_ENABLED=true
# If true, bridge prefers TikTok-only trends; if none are found it falls back automatically.
THEME_DISCOVERY_TIKTOK_ONLY=true
THEME_DISCOVERY_TIKTOK_LOCALE=en
# Note: Creative Center locale pages are often EN-only; use country for DE/US scoping.
# Use DE for Germany-only, ALL for global.
THEME_DISCOVERY_TIKTOK_COUNTRY=ALL
THEME_DISCOVERY_TIKTOK_PERIOD_DAYS=7
THEME_DISCOVERY_TIKTOK_MAX_HASHTAGS=6
# Inspiration feed (most-searched / popular video ideas).
THEME_DISCOVERY_TIKTOK_MAX_INSPIRATION=6
# Optional fallback only; set 0 to disable music trends.
THEME_DISCOVERY_TIKTOK_MAX_SONGS=0
THEME_AVOID_RECENT_TITLES=10
THEME_HARD_BAN_TERMS=voicemail,last voicemail,voice note,missed call
RANDOM_SEEDS_ENABLED=true
RANDOM_SEED_WORD_COUNT=3
# Optional custom seed pool (comma-separated). If empty, vm_bridge uses an internal pool.
# RANDOM_SEED_WORDS=clock,train,receipt,storm,mirror,market
IDLE_LOG_EVERY_SEC=300

# Optional override. If empty, vm_bridge reads token from
# $OPENCLAW_HOME/openclaw.json -> channels.discord.token
DISCORD_BOT_TOKEN=
