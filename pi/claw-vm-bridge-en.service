[Unit]
Description=Claw VM Bridge EN (#general)
After=network.target

[Service]
Type=simple
WorkingDirectory=%h
Environment="PATH=%h/.npm-global/bin:%h/.local/bin:%h/bin:/usr/local/bin:/usr/bin:/bin"
ExecStart=%h/.openclaw/vm_bridge_loop_en.sh
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
