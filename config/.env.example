# VM access (where OpenClaw/cron runs)
VM_USER=your_vm_user
VM_HOST=your_vm_ip
VM_SSH_PORT=22
VM_SSH_PASSWORD=
VM_OPENCLAW_HOME=/home/your_vm_user/.openclaw

# OpenClaw routing
DISCORD_CHANNEL_ID=your_discord_channel_id
CRON_JOB_ID=your_cron_job_id

# Video backend on Mac
# local_synth = fully local generated animated clip (no billing API)
# api         = call external endpoint
VIDEO_BACKEND=local_synth

# Only needed when VIDEO_BACKEND=api
VIDEO_API_ENDPOINT=
VIDEO_API_KEY=
VIDEO_API_KEY_HEADER=Authorization
BASE_CLIP_SECONDS=8
ASPECT_RATIO=9:16

# Final looped clip target
MIN_SECONDS=40
MAX_SECONDS=60
TARGET_SECONDS=50

# Optional: send generated video back to Discord via webhook
DISCORD_WEBHOOK_URL=
