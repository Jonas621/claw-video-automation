MAC_API_HOST=127.0.0.1
MAC_API_PORT=8787
MAC_API_TOKEN=change_me

# Clip backend:
# - local_synth : fallback (fast, abstract visuals)
# - comfyui     : real local gen via ComfyUI workflow
VIDEO_BACKEND=local_synth

# Optional local prompt enhancement (text only, not video generation)
OLLAMA_API_URL=http://127.0.0.1:11434
OLLAMA_PROMPT_MODEL=

BASE_CLIP_SECONDS=10
BASE_CLIP_VARIANTS=3
BASE_VARIANT_RETRIES=1
MIN_SECONDS=40
MAX_SECONDS=60
TARGET_SECONDS=50

# Motion layer to avoid static-looking clips
MOTION_ENABLED=false
MOTION_ZOOM=1.09
MOTION_SWAY_X=16
MOTION_SWAY_Y=24
MOTION_FREQ_X=0.42
MOTION_FREQ_Y=0.34
MOTION_NOISE=4
MOTION_CONTRAST=1.06
MOTION_SATURATION=1.09

# Voiceover (full upload clip)
VOICEOVER_ENABLED=true
VOICEOVER_BACKEND=macos_say
VOICEOVER_VOICE=Samantha
VOICEOVER_RATE_WPM=178
# Optional realistic neural backend (free, internet required):
# - install: python3 -m pip install edge-tts
# - set backend: VOICEOVER_BACKEND=edge_tts
# - pick a neural voice (examples): en-US-AvaMultilingualNeural, en-US-GuyNeural
# - if edge-tts is not on PATH, set VOICEOVER_EDGE_TTS_BIN to full path
VOICEOVER_EDGE_TTS_BIN=edge-tts
VOICEOVER_EDGE_VOICE=en-US-AvaMultilingualNeural
# Optional auto-voice matrix (free edge-tts voices):
# - language auto-detect: VOICEOVER_LANGUAGE_MODE=auto (or fixed en/de)
# - gender auto/balanced: VOICEOVER_GENDER_MODE=auto (or female/male/random)
VOICEOVER_EDGE_VARIANTS_ENABLED=true
VOICEOVER_LANGUAGE_MODE=auto
VOICEOVER_GENDER_MODE=auto
VOICEOVER_EDGE_VOICE_EN_FEMALE=en-US-AvaMultilingualNeural
VOICEOVER_EDGE_VOICE_EN_MALE=en-US-GuyNeural
VOICEOVER_EDGE_VOICE_DE_FEMALE=de-DE-KatjaNeural
VOICEOVER_EDGE_VOICE_DE_MALE=de-DE-ConradNeural
VOICEOVER_EDGE_ALLOWED_CHOICES=en-US-AvaMultilingualNeural,en-US-GuyNeural,de-DE-KatjaNeural,de-DE-ConradNeural
# Optional per-channel language override:
# VOICEOVER_LANGUAGE_CHANNEL_<YOUR_CHANNEL_ID_DE>=de
# VOICEOVER_LANGUAGE_CHANNEL_<YOUR_CHANNEL_ID_EN>=en
VOICEOVER_EDGE_RATE=+0%
VOICEOVER_EDGE_PITCH=+0Hz
VOICEOVER_EDGE_VOLUME=+0%
VOICEOVER_EDGE_TIMEOUT_SEC=240
VOICEOVER_EDGE_RETRIES=1
VOICEOVER_EDGE_RETRY_DELAY_SEC=2.0
VOICEOVER_EDGE_FALLBACK_ENABLED=true
VOICEOVER_EDGE_FALLBACK_BACKEND=macos_say
VOICEOVER_EDGE_FALLBACK_ON_TIMEOUT=true
VOICEOVER_GAIN_DB=2.5
VOICEOVER_MAX_CHARS=900
BGM_ENABLED=true
BGM_LEVEL_DB=-3
BGM_DUCKING_ENABLED=true
BGM_DUCK_THRESHOLD=0.08
BGM_DUCK_RATIO=3
BGM_DUCK_ATTACK_MS=14
BGM_DUCK_RELEASE_MS=180
BGM_FADE_IN_SEC=0.5
BGM_FADE_OUT_SEC=0.8
BGM_SYNTH_GAIN_DB=0.0
VOICEOVER_CAPTIONS_ENABLED=true
VOICEOVER_CAPTIONS_MIN_WORDS=2
VOICEOVER_CAPTIONS_MAX_WORDS=4
VOICEOVER_CAPTIONS_MAX_CHARS=32
VOICEOVER_CAPTIONS_MAX_CHUNKS=60
# Subtitle timing tuning (used for weighted fallback and post-merge spacing)
VOICEOVER_CAPTIONS_LEAD_IN_SEC=0.03
VOICEOVER_CAPTIONS_GAP_SEC=0.05
VOICEOVER_CAPTIONS_TAIL_HOLD_SEC=0.10
VOICEOVER_CAPTIONS_MIN_SEG_SEC=0.16
VOICEOVER_CAPTIONS_FONT_FILE=/System/Library/Fonts/Supplemental/Impact.ttf
VOICEOVER_CAPTIONS_FONT_SIZE=34
VOICEOVER_CAPTIONS_Y_FRAC=0.65
VOICEOVER_CAPTIONS_DISPLAY_SEC=2.8
VOICEOVER_CAPTIONS_TEXT_COLOR=#FFFFFF
VOICEOVER_CAPTIONS_STROKE_COLOR=#000000F0
VOICEOVER_CAPTIONS_STROKE_WIDTH=3
VOICEOVER_CAPTIONS_CARD_COLOR=#00000000
VOICEOVER_CAPTIONS_CARD_BORDER_COLOR=#00000000
VOICEOVER_CAPTIONS_CARD_BORDER_WIDTH=0
PROMPT_STYLE_HINT=stylized anime-inspired cinematic art, clean linework, cel shading, strong composition, dramatic color grading, coherent character silhouettes, visually pleasing storybook aesthetic
PROMPT_STABILITY_ENABLED=true
PROMPT_STABILITY_HINT=single primary subject, consistent identity across frames, same face and clothing, same key props, no morphing or transformation, physically plausible motion, clean anatomy
# Optional hard lock for recurring hero/object appearance across shots.
PROMPT_SUBJECT_LOCK=
# Visual plan merge mode: anchor (recommended), full, none
PROMPT_VISUAL_PLAN_MODE=anchor
PROMPT_VISUAL_PLAN_MAX_ITEMS=2
PROMPT_SCENE_HINT_MAX_ITEMS=6
# Keep off by default; text-beat words are often too abstract for scene prompting.
PROMPT_INCLUDE_TEXT_BEATS_IN_SCENE_HINTS=false
# Set to 0 to disable truncation.
PROMPT_MAX_CHARS=700
PROMPT_SCENE_MAX_CHARS=820
# Additional cap for base prompt reused per shot to keep room for shot wrapper constraints.
PROMPT_BASE_FOR_SHOTS_MAX_CHARS=420
PROMPT_AUTO_SHOT_WRAPPER_ENABLED=true
# Use "|" between recipes (recommended), e.g. recipe1|recipe2|recipe3
PROMPT_SHOT_RECIPES=medium-wide establish controlled dolly-in clean silhouette readable background separation|tight close-up on face and hands shallow depth feel emotional micro-expression focus|dynamic side tracking subtle parallax stable subject lock no sudden jumps
PROMPT_SHOT_CONTINUITY_HINT=same person identity and outfit, same key props, consistent lighting logic, no morphing
PROMPT_QUALITY_HINT=high detail, clean edges, coherent anatomy, coherent geometry, consistent temporal motion
PROMPT_MOTION_HINT=natural motion cadence, no flicker, no warping, no abrupt camera direction changes
TEXT_BEATS_ENABLED=true
TEXT_BEATS_FONT_FILE=/System/Library/Fonts/Supplemental/Impact.ttf
TEXT_BEATS_FONT_SIZE=42
TEXT_BEATS_Y_FRAC=0.22
TEXT_BEATS_DISPLAY_SEC=2.4
TEXT_BEATS_TIMED_MIN_SEC=2.0
TEXT_BEATS_TIMED_MAX_SEC=3.0
TEXT_BEATS_TIMED_TARGET_SEC=2.4
TEXT_BEATS_TIMED_GAP_SEC=0.08
TEXT_BEATS_TEXT_COLOR=#FFFFFF
TEXT_BEATS_STROKE_COLOR=#000000F0
TEXT_BEATS_STROKE_WIDTH=3
TEXT_BEATS_CARD_COLOR=#00000000
TEXT_BEATS_CARD_BORDER_COLOR=#00000000
TEXT_BEATS_CARD_BORDER_WIDTH=0
TEXT_BEATS_EXTRA_ENABLED=false
TEXT_BEATS_EXTRA_FONT_FILE=/System/Library/Fonts/Supplemental/Impact.ttf
TEXT_BEATS_EXTRA_FONT_SIZE=62
TEXT_BEATS_EXTRA_Y_FRAC=0.12
TEXT_BEATS_EXTRA_DISPLAY_SEC=4.5
TEXT_BEATS_EXTRA_TEXT_COLOR=#FFFFFF
TEXT_BEATS_EXTRA_STROKE_COLOR=#0B1F3AF0
TEXT_BEATS_EXTRA_STROKE_WIDTH=4
TEXT_BEATS_EXTRA_CARD_COLOR=#00000000
TEXT_BEATS_EXTRA_CARD_BORDER_COLOR=#00000000
TEXT_BEATS_EXTRA_CARD_BORDER_WIDTH=0
# Auto-clean generated output folders older than N days.
OUTPUT_CLEANUP_ENABLED=true
OUTPUT_RETENTION_DAYS=7
# Auto-clean stale ComfyUI previews (only matching pattern in COMFYUI_OUTPUT_DIR).
COMFYUI_PREVIEW_CLEANUP_ENABLED=true
COMFYUI_PREVIEW_RETENTION_DAYS=2
COMFYUI_PREVIEW_PATTERN=claw_preview*
# After successful generate, keep only the final clip in output/<story_id>/.
OUTPUT_PRUNE_INTERMEDIATES=false
# Keep tiny metadata text files (story/prompt) when pruning intermediates.
OUTPUT_PRUNE_KEEP_TEXT_FILES=true

# ComfyUI backend settings (required when VIDEO_BACKEND=comfyui)
COMFYUI_API_URL=http://127.0.0.1:8188
COMFYUI_DIR=/Users/YOUR_USERNAME/ComfyUI
COMFYUI_OUTPUT_DIR=/Users/YOUR_USERNAME/ComfyUI/output
COMFYUI_PORT=8188
COMFYUI_WORKFLOW_FILE=
COMFYUI_NEGATIVE_PROMPT=text, watermark, logo, subtitles, static frame, blur, low quality, ugly, deformed face, extra limbs, uncanny anatomy, distorted hands, oversharpen, noisy artifact, photoreal uncanny
COMFYUI_NEGATIVE_PROMPT_STABILITY_ENABLED=true
COMFYUI_NEGATIVE_PROMPT_STABILITY_TERMS=morphing, mutation, transformation, identity drift, face swap, duplicate person, floating limbs, fused fingers, warped geometry, melted objects, circular blob artifact
COMFYUI_FPS=12
COMFYUI_MAX_FRAMES=120
COMFYUI_WIDTH=512
COMFYUI_HEIGHT=896
COMFYUI_CHECKPOINT=
COMFYUI_DIFFUSION_MODEL=wan2.2_ti2v_5B_fp16.safetensors
COMFYUI_TEXT_ENCODER=umt5_xxl_fp8_e4m3fn_scaled.safetensors
COMFYUI_VAE_NAME=wan2.2_vae.safetensors
COMFYUI_MODEL_SHIFT=8
COMFYUI_FALLBACK_LOCAL_SYNTH=true
COMFYUI_STEPS=8
COMFYUI_CFG=4.5
COMFYUI_SAMPLER_NAME=uni_pc
COMFYUI_SCHEDULER=simple
COMFYUI_TIMEOUT_SEC=600
COMFYUI_POLL_SEC=2
COMFYUI_INTERRUPTED_COOLDOWN_SEC=300
COMFYUI_TIMEOUT_DIAG_ENABLED=true
COMFYUI_TIMEOUT_LOG_TAIL_LINES=30
COMFYUI_TIMEOUT_LOG_TAIL_CHARS=2200
COMFYUI_ERR_LOG_FILE=/Users/YOUR_USERNAME/claw-video-automation/logs/comfyui.err.log
COMFYUI_RESTART_READY_WAIT_SEC=90
COMFYUI_STEP_WATCHDOG_ENABLED=true
COMFYUI_STEP_WATCHDOG_MAX_SEC_PER_IT=360
COMFYUI_STEP_WATCHDOG_HITS=2
COMFYUI_STEP_WATCHDOG_MIN_ELAPSED_SEC=240
COMFYUI_STALL_WATCHDOG_ENABLED=true
COMFYUI_STALL_WATCHDOG_IDLE_SEC=240
COMFYUI_STALL_WATCHDOG_MIN_ELAPSED_SEC=600
COMFYUI_STALL_WATCHDOG_PROBE_SEC=30

# Preview back to Discord
PREVIEW_DISCORD_WEBHOOK_URL=
# Optional per-source-channel override (vm_bridge sends source_channel_id):
# PREVIEW_DISCORD_WEBHOOK_URL_<YOUR_CHANNEL_ID_EN>=<webhook for #general>
# PREVIEW_DISCORD_WEBHOOK_URL_<YOUR_CHANNEL_ID_DE>=<webhook for #de>
DISCORD_WEBHOOK_URL=

# TikTok posting API (from Mac)
TIKTOK_DRY_RUN=true
TIKTOK_POST_API_ENDPOINT=
TIKTOK_POST_API_TOKEN=
